# Copy to /etc/remote-tools/env and set your auth key before running install.sh
#
# Generate a reusable, non-ephemeral key at:
# https://login.tailscale.com/admin/settings/keys
#
# Recommended key settings:
#   - Reusable: yes
#   - Ephemeral: no
#   - Pre-approved: yes (if using ACL tags)

TS_AUTHKEY=tskey-auth-REPLACE-ME

# Optional: hostname shown in the Tailscale admin console
# TS_HOSTNAME=my-remote-host

# Optional: extra tailscale up flags (defaults enable SSH and route acceptance)
# TS_EXTRA_ARGS=--ssh --accept-routes --advertise-tags=tag:remote
